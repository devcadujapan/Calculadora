<Button>:
    font_size: 32
    background_normal: ''
    background_color: 0.12, 0.12, 0.23, 1  # padrão: número
    color: 0, 1, 0.6, 1

<Calculadora>:
    rows: 7
    padding: 20
    spacing: 10
    canvas.before:
        Color:
            rgba: 0.05, 0.05, 0.09, 1
        Rectangle:
            pos: self.pos
            size: self.size

    TextInput:
        text: root.texto_entrada
        font_size: 40
        multiline: False
        readonly: True
        halign: 'right'
        background_color: 0.1, 0.1, 0.18, 1
        foreground_color: 0.22, 1, 0.08, 1
        size_hint_y: None
        height: 80

    GridLayout:
        cols: 4
        spacing: 10
        size_hint_y: None
        height: 80
        Button:
            text: "0"
            on_press: root.clicar("0")
        Button:
            text: "."
            font_size: 28
            on_press: root.clicar(".")
        Button:
            text: "<<"  # Voltar
            background_color: 0.4, 0, 0, 1
            color: 1, 1, 1, 1
            font_size: 28
            on_press: root.voltar()
        Button:
            text: "C"  # Limpar
            background_color: 0, 0.2, 0.4, 1
            color: 1, 1, 1, 1
            font_size: 28
            on_press: root.limpar()

    GridLayout:
        cols: 4
        spacing: 10
        Button:
            text: "1"
            on_press: root.clicar("1")
        Button:
            text: "2"
            on_press: root.clicar("2")
        Button:
            text: "3"
            on_press: root.clicar("3")
        Button:
            text: "+"
            background_color: 0.16, 0, 0.2, 1
            color: 1, 0.4, 1, 1
            font_size: 28
            on_press: root.clicar("+")

    GridLayout:
        cols: 4
        spacing: 10
        Button:
            text: "4"
            on_press: root.clicar("4")
        Button:
            text: "5"
            on_press: root.clicar("5")
        Button:
            text: "6"
            on_press: root.clicar("6")
        Button:
            text: "-"
            background_color: 0.16, 0, 0.2, 1
            color: 1, 0.4, 1, 1
            font_size: 28
            on_press: root.clicar("-")

    GridLayout:
        cols: 4
        spacing: 10
        Button:
            text: "7"
            on_press: root.clicar("7")
        Button:
            text: "8"
            on_press: root.clicar("8")
        Button:
            text: "9"
            on_press: root.clicar("9")
        Button:
            text: "*"
            background_color: 0.16, 0, 0.2, 1
            color: 1, 0.4, 1, 1
            font_size: 28
            on_press: root.clicar("*")

    GridLayout:
        cols: 4
        spacing: 10
        Button:
            text: "%"
            background_color: 0.133, 0.545, 0.133, 1
            color: 0, 1, 1, 1
            font_size: 28
            on_press: root.clicar("%")
        Button:
            text: "√"
            background_color: 0.133, 0.545, 0.133, 11
            color: 0, 1, 1, 1
            font_size: 28
            on_press: root.clicar("√")
        Button:
            text: "x²"
            background_color: 0.133, 0.545, 0.133, 1
            color: 0, 1, 1, 1
            font_size: 28
            on_press: root.clicar("^2")
        Button:
            text: "/"
            background_color: 0.16, 0, 0.2, 1
            color: 1, 0.4, 1, 1
            font_size: 28
            on_press: root.clicar("/")

    GridLayout:
        cols: 1
        spacing: 10
        Button:
            text: "="
            background_color: 0.8, 0.67, 0, 1
            color: 0, 0, 0, 1
            font_size: 36
            on_press: root.calcular()

